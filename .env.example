# Core runtime
PORT=5000
# MongoDB Atlas URI example (recommended for production):
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<app>
# Local MongoDB URI fallback:
# MONGO_URI=mongodb://127.0.0.1:27017/digital_wardrobe
MONGO_URI=
# Optional explicit DB name override (recommended with Atlas)
MONGO_DB_NAME=digital_wardrobe
JWT_SECRET=replace-with-strong-secret
AUTO_CLEANUP_ORPHANS=false

# Upload limits and cleanup
IMAGE_UPLOAD_MAX_MB=5
IMAGE_UPLOAD_MAX_DIMENSION_PX=6000
IMAGE_UPLOAD_MAX_MEGAPIXELS=25
ORPHAN_UPLOAD_RETENTION_DAYS=30

# Storage migration (safe defaults)
# local: writes/reads from local uploads directory
# cloudinary: writes to Cloudinary, reads via authenticated /api/uploads route fallback
STORAGE_PRIMARY_DRIVER=local

# true keeps local file after cloud upload; safer during migration
# false removes local copy after successful cloud upload
STORAGE_KEEP_LOCAL_COPY=true

# Cloudinary credentials (required only when STORAGE_PRIMARY_DRIVER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional Cloudinary folder prefix
CLOUDINARY_FOLDER=digital-wardrobe
