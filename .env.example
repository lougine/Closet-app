# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=replace-with-a-strong-secret
# Comma-separated browser origins allowed by CORS.
# In production, leaving this empty blocks all browser origins.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:8081

# Database
MONGO_URI=mongodb://mongodb:27017/digital_wardrobe
MONGO_DB_NAME=digital_wardrobe

# Optional storage settings
STORAGE_PRIMARY_DRIVER=local
STORAGE_KEEP_LOCAL_COPY=false
IMAGE_UPLOAD_MAX_MB=5
IMAGE_UPLOAD_MAX_DIMENSION_PX=6000
IMAGE_UPLOAD_MAX_MEGAPIXELS=25
ORPHAN_UPLOAD_RETENTION_DAYS=30

# Optional Cloudinary settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=digital-wardrobe

# Optional feature toggles
AUTO_CLEANUP_ORPHANS=false
ALLOW_ATLAS_ORPHAN_CLEANUP=false
ALLOW_TEST_ATLAS=false
ENABLE_SEED_ENDPOINT=false
SEED_API_SECRET=

# Optional third-party services
SERPER_API_KEY=
REMOVE_BG_API_KEY=
# Comma-separated allowlist of remote hosts accepted for remove background by URL.
# In production, this should be explicitly set to trusted domains only.
# Example: REMOVE_BG_ALLOWED_IMAGE_HOSTS=images.example.com,cdn.example.com
REMOVE_BG_ALLOWED_IMAGE_HOSTS=
