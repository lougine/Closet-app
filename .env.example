# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=replace-with-a-strong-secret

# Database
MONGO_URI=mongodb://mongodb:27017/digital_wardrobe
MONGO_DB_NAME=digital_wardrobe

# Optional storage settings
STORAGE_PRIMARY_DRIVER=local
STORAGE_KEEP_LOCAL_COPY=false
IMAGE_UPLOAD_MAX_MB=5
IMAGE_UPLOAD_MAX_DIMENSION_PX=6000
IMAGE_UPLOAD_MAX_MEGAPIXELS=25
ORPHAN_UPLOAD_RETENTION_DAYS=30

# Optional Cloudinary settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=digital-wardrobe

# Optional feature toggles
AUTO_CLEANUP_ORPHANS=false
ALLOW_ATLAS_ORPHAN_CLEANUP=false
ALLOW_TEST_ATLAS=false
ENABLE_SEED_ENDPOINT=false
SEED_API_SECRET=

# Optional third-party services
SERPER_API_KEY=
REMOVE_BG_API_KEY=
